<script>
function toggle(id) {
  const body = document.getElementById(id);
  const ch = document.getElementById('ch-' + id);
  const isOpen = body.classList.contains('open');
  body.classList.toggle('open', !isOpen);
  body.style.display = isOpen ? 'none' : 'block';
  ch.classList.toggle('open', !isOpen);
}

function scrollTo(id) {
  document.getElementById(id).scrollIntoView({ behavior: 'smooth', block: 'start' });
  document.querySelectorAll('.hero-pill').forEach(p => p.classList.remove('active'));
  event.target.classList.add('active');
  const secMap = { def: 's1', cycle: 's2', factors: 's3', organic: 's4', measure: 's5', practices: 's6' };
  const secId = secMap[id];
  if (secId) {
    const body = document.getElementById(secId);
    const ch = document.getElementById('ch-' + secId);
    body.classList.add('open');
    body.style.display = 'block';
    if (ch) ch.classList.add('open');
  }
}

function calcSOC() {
  const acres = parseInt(document.getElementById('farm-acres').value);
  const curr = parseInt(document.getElementById('curr-soc').value) / 10;
  const target = parseInt(document.getElementById('target-soc').value) / 10;
  document.getElementById('acres-val').textContent = acres;
  document.getElementById('soc-val').textContent = curr.toFixed(1);
  document.getElementById('target-val').textContent = target.toFixed(1);
  const diff = Math.max(0, target - curr);
  const compost = Math.round(acres * diff * 25 * 10) / 10;
  const years = diff <= 0.3 ? '1–2' : diff <= 0.8 ? '3–5' : '5–8';
  document.getElementById('compost-need').textContent = compost;
  document.getElementById('years-need').textContent = years;
}


