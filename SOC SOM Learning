let cycleTimer = null;

function showCS(i) {
  // Update step buttons
  for (let j = 0; j < 6; j++) {
    const el = document.getElementById('cs' + j);
    const dot = document.getElementById('dot' + j);
    if (el) el.classList.toggle('icc-active', j === i);
    if (dot) dot.classList.toggle('icc-active', j === i);
  }
  // Render detail panel
  const d = cycleSteps[i];
  const det = document.getElementById('icc-detail');
  if (det) {
    det.innerHTML = '<div class="dh"><span class="di">' + d.ico + '</span><div><div class="dt">' + d.title + '</div><div class="ds">' + d.sub + '</div></div></div>' +
      '<div class="db">' + d.body + '</div>' +
      '<div class="df">' + d.farmer + '</div>';
  }
}

// Auto-advance cycle every 5 seconds when section is open
function startCycleAuto() {
  let cur = 0;
  showCS(0);
  cycleTimer = setInterval(function() {
    cur = (cur + 1) % 6;
    showCS(cur);
  }, 5000);
}

window.addEventListener('load', () => {
  showCS(0);
  calcSOC();
  ['b1','b2','b3','b4'].forEach(id => {
    const el = document.getElementById(id);
    if (el) { const w = el.style.width; el.style.width = '0'; setTimeout(() => el.style.width = w, 100); }
  });
});
