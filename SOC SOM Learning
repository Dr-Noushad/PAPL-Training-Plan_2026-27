<style>
  @import url('https://fonts.googleapis.com/css2?family=Noto+Sans+Devanagari:wght@300;400;600;700;900&display=swap');
  :root {
    --soil-dark: #3d2208;
    --soil-mid: #6b3d1e;
    --soil-light: #a0693a;
    --soil-pale: #c9935a;
    --green-dark: #1a3a08;
    --green-mid: #2d6a10;
    --green-light: #4a9a1a;
    --amber: #f5a623;
    --amber-lt: #fdd87a;
    --blue: #1a6b9e;
    --cream: #faf5e8;
  }
  .soc-wrap {
    font-family: 'Noto Sans Devanagari', sans-serif;
    padding: 0;
    max-width: 100%;
  }
  .sr-only { position:absolute;width:1px;height:1px;padding:0;margin:-1px;overflow:hidden;clip:rect(0,0,0,0);border:0; }

  /* Hero header */
  .soc-hero {
    background: var(--soil-dark);
    border-radius: var(--border-radius-lg);
    padding: 24px 24px 20px;
    margin-bottom: 20px;
    position: relative;
    overflow: hidden;
  }
  .soc-hero::before {
    content: '';
    position: absolute; inset: 0;
    background: repeating-linear-gradient(0deg, transparent, transparent 18px, rgba(255,255,255,0.02) 18px, rgba(255,255,255,0.02) 19px);
    pointer-events: none;
  }
  .hero-badge {
    display: inline-block;
    background: rgba(245,166,35,0.2);
    border: 1px solid rgba(245,166,35,0.4);
    color: var(--amber-lt);
    font-size: 10px; font-weight: 700;
    letter-spacing: 2px; text-transform: uppercase;
    padding: 4px 12px; border-radius: 20px;
    margin-bottom: 12px;
  }
  .hero-title {
    font-size: 26px; font-weight: 900; color: #fff;
    line-height: 1.2; margin-bottom: 6px;
  }
  .hero-title em { color: var(--amber); font-style: normal; }
  .hero-sub { font-size: 13px; color: #a8d878; line-height: 1.7; margin-bottom: 16px; }
  .hero-pills { display: flex; flex-wrap: wrap; gap: 8px; }
  .hero-pill {
    background: rgba(255,255,255,0.08);
    border: 1px solid rgba(255,255,255,0.15);
    color: #d4f0b0; font-size: 11px; font-weight: 600;
    padding: 5px 12px; border-radius: 16px; cursor: pointer;
    transition: all 0.2s;
  }
  .hero-pill:hover { background: var(--amber); color: var(--soil-dark); border-color: var(--amber); }
  .hero-pill.active { background: var(--amber); color: var(--soil-dark); border-color: var(--amber); }

  /* Section cards */
  .sec-card {
    background: var(--color-background-primary);
    border: 0.5px solid var(--color-border-tertiary);
    border-radius: var(--border-radius-lg);
    margin-bottom: 16px;
    overflow: hidden;
  }
  .sec-head {
    display: flex; align-items: center; gap: 12px;
    padding: 16px 18px;
    cursor: pointer;
    border-bottom: 0.5px solid var(--color-border-tertiary);
    background: var(--color-background-secondary);
    user-select: none;
  }
  .sec-head:hover { background: var(--color-background-tertiary); }
  .sec-icon {
    width: 36px; height: 36px; border-radius: var(--border-radius-md);
    display: flex; align-items: center; justify-content: center;
    font-size: 18px; flex-shrink: 0;
  }
  .sec-icon.soil { background: #c9935a33; }
  .sec-icon.carbon { background: #2d6a1022; }
  .sec-icon.factor { background: #f5a62322; }
  .sec-icon.farm { background: #1a6b9e22; }
  .sec-icon.measure { background: #8b2d6a22; }
  .sec-title { flex: 1; }
  .sec-title h3 { font-size: 15px; font-weight: 500; color: var(--color-text-primary); margin: 0 0 2px; }
  .sec-title p { font-size: 12px; color: var(--color-text-secondary); margin: 0; }
  .sec-chevron { font-size: 14px; color: var(--color-text-tertiary); transition: transform 0.3s; }
  .sec-chevron.open { transform: rotate(180deg); }
  .sec-body { padding: 18px; display: none; }
  .sec-body.open { display: block; }

  /* Info boxes */
  .info-row { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-bottom: 14px; }
  .info-box {
    background: var(--color-background-secondary);
    border-radius: var(--border-radius-md);
    padding: 14px;
    border-left: 3px solid var(--green-mid);
  }
  .info-box.amber { border-left-color: var(--amber); }
  .info-box.blue { border-left-color: var(--blue); }
  .info-box.soil-c { border-left-color: var(--soil-mid); }
  .info-box h4 { font-size: 12px; font-weight: 500; color: var(--color-text-primary); margin: 0 0 5px; }
  .info-box p { font-size: 12px; color: var(--color-text-secondary); line-height: 1.65; margin: 0; }
  .info-box .big-num { font-size: 22px; font-weight: 700; color: var(--green-mid); line-height: 1; margin-bottom: 4px; }
  .info-box.amber .big-num { color: #BA7517; }
  .info-box.soil-c .big-num { color: var(--soil-mid); }

  /* Body text */
  .body-text { font-size: 13px; color: var(--color-text-secondary); line-height: 1.75; margin-bottom: 12px; }
  .body-text strong { color: var(--color-text-primary); font-weight: 500; }

  /* Highlight box */
  .hi-box {
    background: #EAF3DE;
    border-radius: var(--border-radius-md);
    padding: 12px 14px; margin-bottom: 12px;
  }
  .hi-box p { font-size: 12px; color: #27500A; line-height: 1.7; margin: 0; }
  .hi-box strong { font-weight: 600; }

  /* Factor cards */
  .factor-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; margin-bottom: 12px; }
  .factor-card {
    background: var(--color-background-secondary);
    border-radius: var(--border-radius-md);
    padding: 12px;
    border-top: 2px solid var(--green-mid);
  }
  .factor-card:nth-child(even) { border-top-color: var(--amber); }
  .factor-card:nth-child(3n) { border-top-color: var(--blue); }
  .factor-card h4 { font-size: 12px; font-weight: 500; color: var(--color-text-primary); margin: 0 0 4px; }
  .factor-card p { font-size: 11px; color: var(--color-text-secondary); line-height: 1.55; margin: 0; }
  .factor-ico { font-size: 20px; margin-bottom: 6px; }

  /* Comparison bar */
  .comp-bar { margin-bottom: 14px; }
  .comp-label { display: flex; justify-content: space-between; font-size: 12px; color: var(--color-text-secondary); margin-bottom: 4px; }
  .comp-track { height: 10px; background: var(--color-background-tertiary); border-radius: 5px; overflow: hidden; }
  .comp-fill { height: 100%; border-radius: 5px; transition: width 1s ease; }

  /* Soil layer diagram */
  .soil-layers { border-radius: var(--border-radius-md); overflow: hidden; margin-bottom: 12px; }
  .layer { padding: 10px 14px; display: flex; align-items: center; gap: 12px; }
  .layer-ico { font-size: 18px; flex-shrink: 0; }
  .layer-body { flex: 1; }
  .layer-title { font-size: 12px; font-weight: 500; color: #fff; margin: 0 0 1px; }
  .layer-desc { font-size: 11px; color: rgba(255,255,255,0.7); margin: 0; line-height: 1.4; }
  .layer-val { font-size: 13px; font-weight: 700; color: var(--amber-lt); flex-shrink: 0; }

  /* Interactive SOC calculator */
  .calc-box {
    background: var(--color-background-secondary);
    border-radius: var(--border-radius-md);
    padding: 16px; margin-bottom: 12px;
  }
  .calc-title { font-size: 13px; font-weight: 500; color: var(--color-text-primary); margin-bottom: 12px; }
  .slider-row { display: flex; align-items: center; gap: 10px; margin-bottom: 10px; }
  .slider-label { font-size: 12px; color: var(--color-text-secondary); min-width: 100px; }
  .slider-val { font-size: 13px; font-weight: 500; color: var(--color-text-primary); min-width: 40px; text-align: right; }
  .result-box {
    background: var(--color-background-primary);
    border: 0.5px solid var(--color-border-tertiary);
    border-radius: var(--border-radius-md);
    padding: 12px; margin-top: 12px;
    display: grid; grid-template-columns: 1fr 1fr; gap: 10px;
  }
  .result-item { text-align: center; }
  .result-num { font-size: 20px; font-weight: 700; color: var(--green-mid); line-height: 1; margin-bottom: 3px; }
  .result-num.amber { color: #BA7517; }
  .result-lbl { font-size: 10px; color: var(--color-text-tertiary); }

  /* Practices list */
  .practice-list { display: flex; flex-direction: column; gap: 8px; margin-bottom: 12px; }
  .practice-item {
    display: flex; align-items: flex-start; gap: 10px;
    background: var(--color-background-secondary);
    border-radius: var(--border-radius-md);
    padding: 11px 13px;
    border-left: 2.5px solid var(--green-mid);
  }
  .practice-item:nth-child(even) { border-left-color: var(--amber); }
  .practice-ico { font-size: 18px; flex-shrink: 0; margin-top: 1px; }
  .practice-body h4 { font-size: 12px; font-weight: 500; color: var(--color-text-primary); margin: 0 0 2px; }
  .practice-body p { font-size: 11px; color: var(--color-text-secondary); line-height: 1.55; margin: 0; }

  /* SOC cycle diagram */
  .cycle-wrap { background: var(--color-background-secondary); border-radius: var(--border-radius-md); padding: 4px; margin-bottom: 12px; }

  /* ── Interactive Carbon Cycle ── */
  .icc-wrap {
    background: var(--color-background-secondary);
    border-radius: var(--border-radius-md);
    padding: 16px; margin-bottom: 14px;
  }
  .icc-label {
    font-size: 11px; font-weight: 700; color: var(--color-text-secondary);
    text-transform: uppercase; letter-spacing: 0.8px;
    text-align: center; margin-bottom: 14px;
  }
  .icc-ring {
    display: grid; grid-template-columns: 1fr 1fr 1fr;
    gap: 8px; margin-bottom: 14px;
  }
  .icc-step {
    background: var(--color-background-primary);
    border: 2px solid var(--color-border-tertiary);
    border-radius: 12px; padding: 12px 8px;
    text-align: center; cursor: pointer;
    transition: all 0.2s; position: relative;
  }
  .icc-step:hover { border-color: var(--green-mid); transform: translateY(-2px); }
  .icc-step.icc-active {
    border-color: var(--amber);
    background: #fef9ee;
    box-shadow: 0 4px 16px rgba(245,166,35,0.2);
    transform: translateY(-3px);
  }
  .icc-step .sn {
    position: absolute; top: -10px; left: 50%; transform: translateX(-50%);
    width: 20px; height: 20px; border-radius: 50%;
    background: var(--soil-dark); color: var(--amber-lt);
    font-size: 10px; font-weight: 700;
    display: flex; align-items: center; justify-content: center;
  }
  .icc-step.icc-active .sn { background: var(--amber); color: var(--soil-dark); }
  .icc-step .si { font-size: 24px; display: block; margin-bottom: 4px; }
  .icc-step .sl { font-size: 11px; font-weight: 600; color: var(--color-text-primary); line-height: 1.3; }
  .icc-detail {
    background: var(--color-background-primary);
    border: 1.5px solid var(--amber);
    border-radius: 10px; padding: 14px 16px;
    min-height: 110px; transition: all 0.25s;
  }
  .icc-detail .dh { display: flex; align-items: center; gap: 10px; margin-bottom: 8px; }
  .icc-detail .di { font-size: 28px; flex-shrink: 0; }
  .icc-detail .dt { font-size: 14px; font-weight: 700; color: var(--color-text-primary); line-height: 1.2; }
  .icc-detail .ds { font-size: 11px; color: var(--color-text-tertiary); }
  .icc-detail .db { font-size: 12px; color: var(--color-text-secondary); line-height: 1.7; margin-bottom: 8px; }
  .icc-detail .df {
    background: #EAF3DE; border-radius: 8px;
    padding: 8px 12px; font-size: 12px; color: #27500A; line-height: 1.6;
  }
  .icc-detail .df strong { font-weight: 600; }
  .icc-nav { display: flex; justify-content: center; gap: 6px; margin-top: 12px; }
  .icc-dot {
    width: 8px; height: 8px; border-radius: 4px;
    background: var(--color-border-tertiary); cursor: pointer; transition: all 0.2s;
  }
  .icc-dot.icc-active { background: var(--amber); width: 22px; }

  /* ── Trainer Tip Box ── */
  .trainer-tip {
    background: #f0f7ff;
    border: 1.5px dashed #1a6b9e;
    border-radius: var(--border-radius-md);
    padding: 12px 14px; margin-top: 12px; margin-bottom: 4px;
  }
  .trainer-tip .tt-head {
    font-size: 11px; font-weight: 700; color: #1a6b9e;
    text-transform: uppercase; letter-spacing: 0.6px; margin-bottom: 5px;
  }
  .trainer-tip p { font-size: 12px; color: #1a3d5c; line-height: 1.65; margin: 0; }

  /* Quick ref table */
  .ref-table { width: 100%; border-collapse: collapse; font-size: 12px; margin-bottom: 12px; }
  .ref-table th { background: var(--soil-dark); color: var(--amber-lt); padding: 8px 10px; text-align: left; font-weight: 500; }
  .ref-table td { padding: 8px 10px; border-bottom: 0.5px solid var(--color-border-tertiary); color: var(--color-text-secondary); }
  .ref-table tr:last-child td { border-bottom: none; }
  .ref-table tr:hover td { background: var(--color-background-secondary); }
  .status-good { color: #3B6D11; font-weight: 500; }
  .status-avg { color: #854F0B; font-weight: 500; }
  .status-poor { color: #A32D2D; font-weight: 500; }

  /* CTA */
  .cta-row { display: flex; gap: 8px; flex-wrap: wrap; margin-top: 4px; }
  .cta-btn {
    flex: 1; min-width: 120px;
    padding: 10px 14px; border-radius: var(--border-radius-md);
    font-size: 12px; font-weight: 500; cursor: pointer;
    border: 0.5px solid var(--color-border-secondary);
    background: var(--color-background-secondary);
    color: var(--color-text-primary);
    font-family: 'Noto Sans Devanagari', sans-serif;
    transition: all 0.15s; text-align: center;
  }
  .cta-btn:hover { background: var(--color-background-tertiary); }
  .cta-btn.primary { background: var(--green-dark); color: #d4f0b0; border-color: var(--green-dark); }
  .cta-btn.primary:hover { background: var(--green-mid); }

  @keyframes barGrow { from { width: 0; } }
</style>

<div class="soc-wrap">
  <h2 class="sr-only">मृदा कार्बनिक कार्बन (SOC) और मृदा कार्बनिक पदार्थ (SOM) का हिंदी में व्यापक विवरण</h2>

  <!-- HERO -->
  <div class="soc-hero">
    <div class="hero-badge">🌱 PAPL · जैविक खेती प्रशिक्षण</div>
    <div class="hero-title">मृदा कार्बनिक <em>कार्बन</em> एवं<br>मृदा कार्बनिक <em>पदार्थ</em></div>
    <div class="hero-sub">
      SOC और SOM — जैविक खेती की नींव। स्वस्थ मिट्टी का रहस्य यहाँ है।
    </div>
    <div class="hero-pills">
      <span class="hero-pill active" onclick="scrollTo('def')">परिभाषा</span>
      <span class="hero-pill" onclick="scrollTo('cycle')">चक्र</span>
      <span class="hero-pill" onclick="scrollTo('factors')">कारक</span>
      <span class="hero-pill" onclick="scrollTo('organic')">जैविक खेती</span>
      <span class="hero-pill" onclick="scrollTo('measure')">मापन</span>
      <span class="hero-pill" onclick="scrollTo('practices')">क्या करें</span>
    </div>
  </div>

  <!-- SECTION 1: DEFINITION -->
  <div class="sec-card" id="def">
    <div class="sec-head" onclick="toggle('s1')">
      <div class="sec-icon soil">🌍</div>
      <div class="sec-title">
        <h3>SOC और SOM क्या हैं?</h3>
        <p>मूल परिभाषाएं और अंतर</p>
      </div>
      <span class="sec-chevron open" id="ch-s1">▼</span>
    </div>
    <div class="sec-body open" id="s1">
      <div class="body-text">
        <strong>मृदा कार्बनिक पदार्थ (SOM)</strong> — मिट्टी में मौजूद सभी जैविक सामग्री जैसे मृत पौधे, जीव-जंतु, कीड़े, सूक्ष्मजीव और उनके अवशेष। यह मिट्टी की "जीवंतता" की पहचान है।
      </div>
      <div class="body-text">
        <strong>मृदा कार्बनिक कार्बन (SOC)</strong> — SOM का वह हिस्सा जो कार्बन तत्व के रूप में मापा जाता है। SOM में लगभग <strong>58% कार्बन</strong> होता है।
      </div>

      <div class="info-row">
        <div class="info-box">
          <div class="big-num">SOM</div>
          <h4>मृदा कार्बनिक पदार्थ</h4>
          <p>मिट्टी में सभी जैविक सामग्री — पौधे, जीव, सूक्ष्मजीव और उनके अवशेष</p>
        </div>
        <div class="info-box amber">
          <div class="big-num" style="color:#BA7517">SOC</div>
          <h4>मृदा कार्बनिक कार्बन</h4>
          <p>SOM का कार्बन-रूप — SOM का 58% भाग। मापने में आसान और सटीक</p>
        </div>
      </div>

      <div class="hi-box">
        <p>🔗 <strong>सरल सूत्र:</strong> SOM = SOC × 1.724<br>
        यानी अगर मिट्टी में 1% SOC है, तो SOM लगभग 1.72% होगा।</p>
      </div>

      <!-- Soil layers visual -->
      <div class="soil-layers">
        <div class="layer" style="background:#4a2810">
          <span class="layer-ico">🌿</span>
          <div class="layer-body">
            <div class="layer-title">सतह परत (O Horizon) — 0–5 सेमी</div>
            <div class="layer-desc">ताज़े पत्ते, अवशेष, सूक्ष्मजीव — SOM सबसे अधिक</div>
          </div>
          <span class="layer-val">↑ अधिक</span>
        </div>
        <div class="layer" style="background:#6b3d1e">
          <span class="layer-ico">🪱</span>
          <div class="layer-body">
            <div class="layer-title">ऊपरी मृदा (A Horizon) — 5–30 सेमी</div>
            <div class="layer-desc">ह्यूमस, केंचुए, जड़ें — SOC का मुख्य भंडार</div>
          </div>
          <span class="layer-val">SOC: 0.5–3%</span>
        </div>
        <div class="layer" style="background:#8b5e3c">
          <span class="layer-ico">🪨</span>
          <div class="layer-body">
            <div class="layer-title">मध्य मृदा (B Horizon) — 30–60 सेमी</div>
            <div class="layer-desc">खनिज पदार्थ अधिक, जैविक पदार्थ कम</div>
          </div>
          <span class="layer-val">SOC: 0.1–0.5%</span>
        </div>
        <div class="layer" style="background:#a0693a">
          <span class="layer-ico">🏔️</span>
          <div class="layer-body">
            <div class="layer-title">आधार (C Horizon) — 60+ सेमी</div>
            <div class="layer-desc">चट्टान और खनिज — जैविक कार्बन नगण्य</div>
          </div>
          <span class="layer-val">↓ कम</span>
        </div>
      </div>

      <p class="body-text">भारत की अधिकांश कृषि मिट्टी में SOC <strong>0.3–0.8%</strong> के बीच है, जबकि स्वस्थ मिट्टी के लिए <strong>1.5–2.5%</strong> आवश्यक है।</p>

      <div class="trainer-tip">
        <div class="tt-head">🏫 प्रशिक्षक संकेत (Trainer Tip)</div>
        <p>मुट्ठी भर मिट्टी उठाएं और किसानों से पूछें: <em>"इसमें क्या-क्या है?"</em> — जड़ें, कीड़े, रंग, गंध — सब देखें। फिर बताएं: <strong>यह सब मिलकर SOM है। इसका कार्बन हिस्सा SOC है।</strong> यह ठोस अनुभव परिभाषा से ज़्यादा याद रहता है।</p>
      </div>
      <div class="cta-row">
        <button class="cta-btn" onclick="sendPrompt('भारत में मिट्टी की SOC स्थिति और सुधार के तरीके बताएं')">भारत की मिट्टी की स्थिति ↗</button>
        <button class="cta-btn primary" onclick="sendPrompt('ह्यूमस क्या है और यह SOC से कैसे अलग है?')">ह्यूमस क्या है? ↗</button>
      </div>
    </div>
  </div>

  <!-- SECTION 2: SOC CYCLE -->
  <div class="sec-card" id="cycle">
    <div class="sec-head" onclick="toggle('s2')">
      <div class="sec-icon carbon">♻️</div>
      <div class="sec-title">
        <h3>कार्बन चक्र — मिट्टी में कार्बन कैसे आता-जाता है?</h3>
